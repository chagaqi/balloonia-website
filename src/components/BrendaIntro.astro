---
type Props = {
  variant?: 'home' | 'about';
};

const { variant = 'home' } = Astro.props;
---

<section class={`brenda section brenda-${variant}`}>
  <div class="container brenda-grid">
    <div class="brenda-image" aria-hidden="true">
      <svg viewBox="0 0 200 250" preserveAspectRatio="xMidYMid slice">
        <rect width="200" height="250" fill="#efc6b9" />
        <circle cx="100" cy="100" r="40" fill="#d28b75" />
        <path d="M40 230 Q100 160 160 230" fill="#d28b75" />
        <text x="100" y="245" text-anchor="middle" font-family="serif" font-size="10" fill="#3a3a3a">Brenda, portrait coming soon</text>
      </svg>
    </div>
    <div class="brenda-text">
      <p class="eyebrow">The artist</p>
      <h2>The hands behind every install.</h2>
      <p>
        Brenda is the sole artist at Balloonia. Every arch, wall, and ceiling build in the portfolio came out of her studio on Newbold Street in London Ontario. She gravitates toward structural builds and color briefs that take more than a quick read.
      </p>
      {variant === 'home' && (
        <p>
          <a class="brenda-link" href="/about">Read Brenda's story →</a>
        </p>
      )}
    </div>
  </div>
</section>

<style>
  .brenda-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-7);
    align-items: center;
  }
  .brenda-image {
    aspect-ratio: 4 / 5;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-paper-edge);
  }
  .brenda-image svg {
    width: 100%;
    height: 100%;
  }
  .brenda-text h2 {
    max-width: 22ch;
  }
  .brenda-text p {
    color: var(--color-ink-soft);
    font-size: var(--font-size-lg);
    line-height: var(--line-relaxed);
  }
  .brenda-link {
    color: var(--color-accent-deep);
    font-weight: 500;
    text-decoration: underline;
    text-underline-offset: 4px;
  }
  @media (min-width: 768px) {
    .brenda-grid {
      grid-template-columns: 1fr 1.4fr;
      gap: var(--space-8);
    }
  }
</style>
