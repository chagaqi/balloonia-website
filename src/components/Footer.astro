---
import { footerNav } from '../data/nav';
import { business } from '../data/business';

const phone = business.phone;
const phoneTel = phone ? `tel:${phone.replace(/[^0-9+]/g, '')}` : '';
const year = new Date().getFullYear();

const socials = [
  business.social.instagram && { label: 'Instagram', href: business.social.instagram, icon: 'ig' },
  business.social.pinterest && { label: 'Pinterest', href: business.social.pinterest, icon: 'pin' },
].filter(Boolean) as { label: string; href: string; icon: 'ig' | 'pin' }[];
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <p class="footer-name">Balloonia Events</p>
      <p class="footer-pitch">Custom balloon installations in London Ontario. Built fresh, delivered, installed, cleaned up. One artist, every build.</p>
      {socials.length > 0 && (
        <ul class="footer-socials" aria-label="Social media">
          {socials.map((s) => (
            <li>
              <a href={s.href} target="_blank" rel="noopener noreferrer" aria-label={s.label}>
                {s.icon === 'ig' && (
                  <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
                    <rect x="3" y="3" width="18" height="18" rx="5" ry="5" fill="none" stroke="currentColor" stroke-width="1.6"/>
                    <circle cx="12" cy="12" r="4" fill="none" stroke="currentColor" stroke-width="1.6"/>
                    <circle cx="17.5" cy="6.5" r="1.1" fill="currentColor"/>
                  </svg>
                )}
                {s.icon === 'pin' && (
                  <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
                    <circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="1.6"/>
                    <path d="M11 7c-3 0-4.5 2-4.5 4 0 1.4.8 2.4 1.9 2.8.1 0 .2 0 .2-.2l.2-.6c.1-.2 0-.3-.1-.5-.3-.3-.5-.7-.5-1.3 0-1.7 1.3-3.2 3.4-3.2 1.8 0 2.8 1.1 2.8 2.6 0 2-1 3.5-2.4 3.5-.8 0-1.4-.6-1.2-1.4.3-1 .8-2 .8-2.7 0-.6-.4-1.2-1-1.2-.8 0-1.4.9-1.4 2 0 .7.2 1.2.2 1.2L9.1 16c-.4 1.6.1 3.4.1 3.6 0 .1.1.1.2 0 .1-.1 1.4-1.7 1.8-3.2.1-.3.7-2.5.7-2.5.4.7 1.4 1.2 2.5 1.2 3.2 0 5.4-3 5.4-6.8 0-2.9-2.5-5.3-6.3-5.3z" fill="currentColor"/>
                  </svg>
                )}
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>

    <div class="footer-nav">
      <p class="footer-heading">Explore</p>
      <ul>
        {footerNav.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </div>

    <div class="footer-contact">
      <p class="footer-heading">Get in touch</p>
      <ul class="footer-list-plain">
        <li><a href={`mailto:${business.email}`}>{business.email}</a></li>
        {phone && <li><a href={phoneTel}>{phone}</a></li>}
        <li>{business.hoursDisplay}</li>
        <li>{business.address.streetAddress}</li>
        <li>{business.address.addressLocality}, {business.address.addressRegion} {business.address.postalCode}</li>
      </ul>
    </div>

    <div class="footer-cta">
      <p class="footer-heading">Ready to book?</p>
      <a class="footer-cta-button" href="/quote">Get a quote</a>
      <a class="footer-cta-secondary" href={business.honeybookScheduler} target="_blank" rel="noopener noreferrer">Book a discovery call</a>
    </div>
  </div>

  <div class="container footer-meta">
    <p>© {year} Balloonia Events. London, Ontario.</p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--space-9);
    background: var(--color-paper-soft);
    border-top: 1px solid var(--color-line);
    padding: var(--space-8) 0 var(--space-6);
    color: var(--color-ink-soft);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-7);
  }

  .footer-name {
    font-family: var(--font-display);
    font-size: var(--font-size-xl);
    color: var(--color-ink);
    margin-bottom: var(--space-3);
  }

  .footer-pitch {
    color: var(--color-ink-muted);
    font-size: var(--font-size-sm);
    max-width: 38ch;
    margin-bottom: var(--space-4);
  }

  .footer-socials {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: var(--space-3);
  }
  .footer-socials li {
    margin: 0;
  }
  .footer-socials a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    border: 1px solid var(--color-line);
    color: var(--color-ink-soft);
    transition: all var(--duration-fast) var(--ease);
  }
  .footer-socials a:hover {
    color: var(--color-paper);
    background: var(--color-ink);
    border-color: var(--color-ink);
  }

  .footer-heading {
    font-size: var(--font-size-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-ink-muted);
    margin-bottom: var(--space-3);
  }

  .footer-nav ul,
  .footer-contact ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    font-size: var(--font-size-sm);
  }

  .footer-nav a:hover,
  .footer-contact a:hover {
    color: var(--color-accent-deep);
  }

  .footer-cta-button {
    display: inline-block;
    background: var(--color-ink);
    color: var(--color-paper);
    padding: var(--space-3) var(--space-5);
    border-radius: var(--radius-pill);
    font-size: var(--font-size-sm);
    font-weight: 600;
    margin-bottom: var(--space-3);
  }

  .footer-cta-button:hover {
    background: var(--color-accent-deep);
  }

  .footer-cta-secondary {
    display: inline-block;
    font-size: var(--font-size-sm);
    color: var(--color-ink-soft);
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .footer-meta {
    margin-top: var(--space-7);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-line);
    font-size: var(--font-size-xs);
    color: var(--color-ink-muted);
  }

  .footer-meta p {
    margin: 0;
  }

  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: 1.4fr 1fr 1.2fr 1fr;
    }
  }
</style>
