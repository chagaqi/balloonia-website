---
import type { Product } from '../data/catalog/types';
import { shopUrlFor } from '../data/catalog/shopify';

type Props = {
  product: Product;
};

const { product } = Astro.props;
const href = shopUrlFor(product.handle);
---

<a class="product-card" href={href}>
  <div class="product-card-image">
    <img src={product.image.src} alt={product.image.alt} loading="lazy" />
  </div>
  <div class="product-card-body">
    <h3>{product.title}</h3>
    <p class="price">From ${product.startingPrice}</p>
    <span class="view">View details <span aria-hidden="true">→</span></span>
  </div>
</a>

<style>
  .product-card {
    display: flex;
    flex-direction: column;
    background: var(--color-paper);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    overflow: hidden;
    height: 100%;
    transition: transform var(--duration-base) var(--ease);
  }
  .product-card:hover {
    transform: translateY(-2px);
  }
  .product-card-image {
    aspect-ratio: 1 / 1;
    background: var(--color-paper-edge);
  }
  .product-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .product-card-body {
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    flex: 1;
  }
  .product-card-body h3 {
    font-size: var(--font-size-lg);
    margin: 0;
  }
  .price {
    color: var(--color-accent-deep);
    font-weight: 600;
    font-size: var(--font-size-sm);
  }
  .view {
    margin-top: auto;
    color: var(--color-ink-muted);
    font-size: var(--font-size-xs);
  }
</style>
