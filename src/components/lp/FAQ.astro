---
export interface FAQItem {
  q: string;
  a: string;
}

export interface Props {
  items: FAQItem[];
}
const { items } = Astro.props;
---

<section class="faq section-paper section">
  <div class="container-narrow">
    <p class="eyebrow eyebrow--center">Questions</p>
    <h2 class="faq__headline">Everything you might be wondering.</h2>
    <ul class="faq__list" role="list">
      {
        items.map((item) => (
          <li class="faq__item" data-faq-item data-open="false">
            <button class="faq__q" aria-expanded="false">
              <span>{item.q}</span>
              <span class="faq__toggle" aria-hidden="true">+</span>
            </button>
            <div class="faq__a">
              <p>{item.a}</p>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .eyebrow--center {
    text-align: center;
  }

  .faq__headline {
    font-size: var(--type-h2);
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .faq__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid var(--color-paper-soft);
  }

  .faq__item {
    border-bottom: 1px solid var(--color-paper-soft);
  }

  .faq__q {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-md) 0;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 1rem;
    color: var(--color-ink);
    text-align: left;
    background: none;
    border: none;
    cursor: pointer;
  }

  .faq__toggle {
    font-size: 1.25rem;
    color: var(--color-emerald-deep);
    transition: transform var(--duration-base) var(--ease-out);
  }

  .faq__item[data-open='true'] .faq__toggle {
    transform: rotate(45deg);
  }

  .faq__a {
    max-height: 0;
    overflow: hidden;
    transition: max-height var(--duration-base) var(--ease-out);
  }

  .faq__item[data-open='true'] .faq__a {
    max-height: 400px;
    padding-bottom: var(--space-md);
  }

  .faq__a p {
    color: var(--color-ink-soft);
    font-size: var(--type-small);
    line-height: 1.65;
  }
</style>
