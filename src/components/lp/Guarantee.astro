---
export interface Props {
  eyebrow: string;
  headline: string;
  body: string;
  trustPoints: string[];
  primaryCtaLabel: string;
  primaryCtaHref: string;
}
const { eyebrow, headline, body, trustPoints, primaryCtaLabel, primaryCtaHref } = Astro.props;
---

<section class="guarantee section-paper section">
  <div class="container">
    <p class="eyebrow eyebrow--muted guarantee__eyebrow">{eyebrow}</p>
    <h2 class="guarantee__h">{headline}</h2>
    <div class="guarantee__card">
      <p class="guarantee__body">{body}</p>
      <ul class="guarantee__trust" role="list">
        {trustPoints.map((p) => <li>{p}</li>)}
      </ul>
    </div>
    <div class="guarantee__cta">
      <a class="btn btn-primary btn-arrow" href={primaryCtaHref}>{primaryCtaLabel}</a>
    </div>
  </div>
</section>

<style>
  .guarantee__eyebrow {
    text-align: center;
  }

  .guarantee__h {
    font-size: clamp(2rem, 4vw, 3rem);
    text-align: center;
    margin-bottom: var(--space-xl);
    line-height: 1.1;
  }

  .guarantee__card {
    background-color: var(--color-paper-soft);
    border: 1px solid var(--color-ink);
    border-radius: var(--radius-md);
    padding: clamp(2rem, 4vw, 3.5rem);
    max-width: 880px;
    margin: 0 auto var(--space-xl);
  }

  .guarantee__body {
    font-size: 1.1rem;
    line-height: 1.6;
    color: var(--color-ink-soft);
    margin-bottom: var(--space-lg);
  }

  .guarantee__trust {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
    font-family: var(--font-sans);
    font-size: var(--type-micro);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink);
    font-weight: 700;
  }

  .guarantee__trust li {
    position: relative;
    padding-left: var(--space-md);
  }

  .guarantee__trust li:first-child {
    padding-left: 0;
  }

  .guarantee__trust li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 1px;
    height: 12px;
    background-color: var(--color-ink);
  }

  .guarantee__trust li:first-child::before {
    display: none;
  }

  .guarantee__cta {
    display: flex;
    justify-content: center;
  }
</style>
