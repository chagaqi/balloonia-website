---
export interface Props {
  eyebrow?: string;
  headline: string;
  subhead: string;
  primaryCtaLabel: string;
  primaryCtaHref: string;
  secondaryCtaLabel: string;
  secondaryCtaHref: string;
  frictionKiller: string;
  imageCaption?: string;
  heroImage?: string;
  heroImageAlt?: string;
}

const {
  eyebrow,
  headline,
  subhead,
  primaryCtaLabel,
  primaryCtaHref,
  secondaryCtaLabel,
  secondaryCtaHref,
  frictionKiller,
  imageCaption = '',
  heroImage,
  heroImageAlt = '',
} = Astro.props;
---

<section class="hero section-paper">
  <div class="container-wide">
    <div class="hero__grid">
      <div class="hero__copy">
        {eyebrow ? <p class="eyebrow eyebrow--muted">{eyebrow}</p> : null}
        <h1 class="hero__headline">{headline}</h1>
        <p class="hero__subhead">{subhead}</p>
        <div class="hero__cta-stack">
          <a class="btn btn-primary btn-arrow" href={primaryCtaHref}>{primaryCtaLabel}</a>
          <p class="friction-killer">{frictionKiller}</p>
          <a class="cta-secondary" href={secondaryCtaHref}>{secondaryCtaLabel}</a>
        </div>
      </div>
      <div class="hero__media">
        {heroImage ? (
          <img class="hero__img" src={heroImage} alt={heroImageAlt} loading="eager" fetchpriority="high" />
        ) : (
          <div class="placeholder" data-ratio="square">
            [Hero image / video / form that reinforces value prop]
          </div>
        )}
        {imageCaption ? <p class="hero__caption">{imageCaption}</p> : null}
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-block: var(--space-xl) var(--space-2xl);
  }

  .hero__grid {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
  }

  .hero__headline {
    font-size: clamp(1.85rem, 3.4vw, 2.75rem);
    line-height: 1.1;
    margin-bottom: var(--space-md);
  }

  .hero__subhead {
    font-size: clamp(0.95rem, 1.1vw, 1.05rem);
    color: var(--color-ink-soft);
    line-height: 1.55;
    margin-bottom: var(--space-lg);
    max-width: 560px;
  }

  .hero__cta-stack {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
  }

  .hero__media {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .hero__img {
    width: 100%;
    height: auto;
    display: block;
    border: 1px solid var(--color-ink);
    border-radius: var(--radius-md);
    aspect-ratio: 1 / 1;
    object-fit: cover;
  }

  .hero__caption {
    font-size: var(--type-micro);
    color: var(--color-ink-muted);
    text-align: center;
  }

  @media (max-width: 900px) {
    .hero__grid {
      grid-template-columns: 1fr;
    }
    /* Mobile order matches Figma: copy first, image at the bottom of the hero */
  }
</style>
