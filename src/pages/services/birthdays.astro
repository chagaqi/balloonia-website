---
import { getCollection, getEntry, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import FAQAccordion from '../../components/FAQAccordion.astro';
import CTAButton from '../../components/CTAButton.astro';
import ProductGrid from '../../components/ProductGrid.astro';
import ReviewsSlider from '../../components/ReviewsSlider.astro';
import { faqPageSchema } from '../../lib/schema/faqPage';
import { serviceSchema } from '../../lib/schema/service';
import { getAllProducts } from '../../data/catalog/shopify';
import { reviewsByTag } from '../../data/reviews';

const entry = await getEntry('icp', 'birthdays');
if (!entry) throw new Error('Missing icp/birthdays');
const { Content } = await render(entry);

const faqs = (await getCollection('faq'))
  .filter((f) => f.data.pages.includes('birthdays'))
  .sort((a, b) => a.data.order - b.data.order)
  .map((f) => ({ question: f.data.question, body: f.body.trim() }));

const portfolio = (await getCollection('portfolio'))
  .filter((p) => p.data.eventType === 'birthdays')
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 6);

const allProducts = await getAllProducts();
const products = allProducts.filter((p) => p.tags.includes('birthday') || p.tags.includes('kids')).slice(0, 6);
const birthdayReviews = reviewsByTag('birthdays');

const schemas = [
  faqPageSchema(faqs.map((f) => ({ question: f.question, answer: f.body }))),
  serviceSchema({
    name: 'Birthday balloon decor',
    description: 'Birthday arches, walls, number columns, and themed setups for milestone birthdays, kids parties, and adult celebrations.',
    startingPrice: 60,
    url: '/services/birthdays',
  }),
];
---

<BaseLayout
  topic="Birthday Balloon Decor"
  description={entry.data.metaDescription}
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Services', url: '/services' },
    { name: 'Birthdays', url: '/services/birthdays' },
  ]}
  schemas={schemas}
>
  <Hero
    eyebrow="Birthdays"
    headline={entry.data.title}
    subhead={`From $${entry.data.pricingMin} for an entry-tier setup. Milestone parties run up to $${entry.data.pricingMax}.`}
    primaryCta={{ href: '/quote?type=Birthday', label: 'Start a birthday quote' }}
    secondaryCta={{ href: '/portfolio', label: 'See birthday work' }}
    image={products[0]?.image.src ?? entry.data.heroImage}
    imageAlt={products[0]?.image.alt ?? entry.data.heroAlt}
    imageHref="https://shop.balloonia.events/collections/birthdays"
    imageOverlay="Click to order online"
    variant="page"
  />

  <section class="icp-body section">
    <div class="container container-narrow prose">
      <Content />
    </div>
  </section>

  {portfolio.length > 0 && (
    <section class="icp-portfolio section">
      <div class="container">
        <p class="eyebrow">Recent birthdays</p>
        <h2>Birthday work</h2>
        <ul class="portfolio-grid-icp">
          {portfolio.map((item) => (
            <li>
              <img src={item.data.image} alt={item.data.alt} loading="lazy" />
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  {products.length > 0 && (
    <section class="icp-products section">
      <div class="container">
        <header class="section-head">
          <p class="eyebrow">Shop the catalog</p>
          <h2>Birthday balloon products</h2>
          <p class="lede">Themed setups, milestone arches, and kids' birthday packages from the catalog. Custom themes built on request.</p>
        </header>
        <ProductGrid products={products} columns={3} />
        <p class="section-link-wrap">
          <a class="section-link" href="https://shop.balloonia.events/collections/birthdays">View all birthday products →</a>
        </p>
      </div>
    </section>
  )}

  <section class="icp-cta section">
    <div class="container container-narrow text-center">
      <p class="eyebrow">Get a quote</p>
      <h2>Tell us about the birthday.</h2>
      <p class="lede">Send your date, the venue, the age, and the vibe. Brenda quotes within 24 hours.</p>
      <div class="icp-cta-buttons">
        <CTAButton href="/quote" variant="primary" size="lg">Start your quote</CTAButton>
        <CTAButton href="/portfolio" variant="secondary" size="lg">See birthday work</CTAButton>
      </div>
    </div>
  </section>

  {birthdayReviews.length > 0 && (
    <ReviewsSlider reviews={birthdayReviews} heading="What past birthday clients have said." />
  )}

  <FAQAccordion heading="Birthday FAQs" faqs={faqs} />
</BaseLayout>

<style>
  .prose h2 {
    margin-top: var(--space-7);
  }
  .portfolio-grid-icp {
    list-style: none;
    margin: var(--space-5) 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
  }
  .portfolio-grid-icp li { margin: 0; }
  .portfolio-grid-icp img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: var(--radius-md);
    background: var(--color-paper-edge);
  }
  .section-head { margin-bottom: var(--space-6); }
  .icp-cta { background: var(--color-paper-soft); }
  .text-center { text-align: center; }
  .text-center p { margin-left: auto; margin-right: auto; }
  .icp-cta-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    justify-content: center;
    margin-top: var(--space-6);
  }
  @media (min-width: 640px) {
    .portfolio-grid-icp { grid-template-columns: repeat(3, 1fr); }
  }
  @media (min-width: 960px) {
    .portfolio-grid-icp { grid-template-columns: repeat(6, 1fr); }
  }
</style>
