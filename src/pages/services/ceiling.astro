---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import ProductGrid from '../../components/ProductGrid.astro';
import QuoteForm from '../../components/quote/QuoteForm.tsx';
import { serviceSchema } from '../../lib/schema/service';
import { getAllProducts } from '../../data/catalog/shopify';
import '../../styles/quote-form.css';

const allProducts = await getAllProducts();
const products = allProducts.filter((p) => p.tags.includes('ceiling')).slice(0, 9);

const schemas = [
  serviceSchema({
    name: 'Ceiling balloon installations',
    description: 'Overhead balloon clusters, canopies, and floating displays for indoor events in London Ontario.',
    startingPrice: 400,
    url: '/services/ceiling',
  }),
];
---

<BaseLayout
  topic="Ceiling Balloon Installations"
  description="Overhead balloon clusters, canopies, and floating ceiling displays in London Ontario. Indoor weddings, ballroom events, brand activations. From $400."
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Services', url: '/services' },
    { name: 'Ceiling installations', url: '/services/ceiling' },
  ]}
  schemas={schemas}
>
  <Hero
    eyebrow="Install type"
    headline="Ceiling installations"
    subhead="Overhead balloon clusters, canopies, and floating displays. Indoor weddings, ballroom events, brand activations."
    primaryCta={{ href: '/quote', label: 'Start a quote' }}
    secondaryCta={{ href: '/portfolio', label: 'See ceiling work' }}
    image="/images/categories/ceiling.png"
    imageAlt="Ceiling balloon installation in a ballroom"
    variant="page"
  />

  <section class="install-body section">
    <div class="container container-narrow prose">
      <p>
        Ceiling installs are the work most local vendors don't take on. Done right, they transform the volume of the room. Done wrong, they sag, drop balloons mid-event, or fall.
      </p>
      <p>
        Brenda's ceiling builds use rigged anchoring, not tape and prayer. She coordinates with the venue on access and load-in windows. Most ceiling installs stay tight from setup to teardown.
      </p>
    </div>
  </section>

  {products.length > 0 && (
    <section class="install-products section">
      <div class="container">
        <header class="section-head">
          <p class="eyebrow">Shop the catalog</p>
          <h2>Ceiling installs in the catalog</h2>
          <p class="lede">Base packages and stock builds. Custom configurations sized to your ceiling height on request.</p>
        </header>
        <ProductGrid products={products} columns={3} />
        <p class="section-link-wrap">
          <a class="section-link" href="https://shop.balloonia.events/collections/ceiling-installations">View all ceiling installs →</a>
        </p>
      </div>
    </section>
  )}

  <section class="install-quote section">
    <div class="container">
      <header class="section-head">
        <p class="eyebrow">Custom build</p>
        <h2>Custom ceiling install?</h2>
        <p class="lede">Send your venue, ceiling height, and event date. Brenda quotes within 24 hours.</p>
      </header>
      <QuoteForm client:load />
    </div>
  </section>
</BaseLayout>

<style>
  .prose p { color: var(--color-ink-soft); font-size: var(--font-size-lg); line-height: var(--line-relaxed); }
  .section-head { margin-bottom: var(--space-6); }
  .install-quote { background: var(--color-paper-soft); }
  .section-link { color: var(--color-accent-deep); font-size: var(--font-size-sm); font-weight: 500; text-decoration: underline; text-underline-offset: 4px; }
  .section-link-wrap { margin-top: var(--space-5); }
</style>
