---
import { getCollection, getEntry, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import FAQAccordion from '../../components/FAQAccordion.astro';
import CTAButton from '../../components/CTAButton.astro';
import ProductGrid from '../../components/ProductGrid.astro';
import ReviewsSlider from '../../components/ReviewsSlider.astro';
import { faqPageSchema } from '../../lib/schema/faqPage';
import { serviceSchema } from '../../lib/schema/service';
import { getAllProducts } from '../../data/catalog/shopify';
import { reviewsByTag } from '../../data/reviews';

const entry = await getEntry('icp', 'weddings');
if (!entry) throw new Error('Missing icp/weddings');
const { Content } = await render(entry);

const faqs = (await getCollection('faq'))
  .filter((f) => f.data.pages.includes('weddings'))
  .sort((a, b) => a.data.order - b.data.order)
  .map((f) => ({ question: f.data.question, body: f.body.trim() }));

const portfolio = (await getCollection('portfolio'))
  .filter((p) => p.data.eventType === 'weddings')
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 6);

const allProducts = await getAllProducts();
const products = allProducts.filter((p) => p.tags.includes('wedding')).slice(0, 6);
const weddingReviews = reviewsByTag('weddings');

const schemas = [
  faqPageSchema(faqs.map((f) => ({ question: f.question, answer: f.body }))),
  serviceSchema({
    name: 'Wedding balloon decor',
    description: 'Custom wedding balloon installations including ceremony arches, reception backdrops, garland centerpieces, and ceiling displays.',
    startingPrice: 499,
    url: '/services/weddings',
  }),
];
---

<BaseLayout
  topic="Wedding Balloon Decor"
  description={entry.data.metaDescription}
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Services', url: '/services' },
    { name: 'Weddings', url: '/services/weddings' },
  ]}
  schemas={schemas}
>
  <Hero
    eyebrow="Weddings"
    headline={entry.data.title}
    subhead={`Pricing range: $${entry.data.pricingMin} to $${entry.data.pricingMax} for most weddings.`}
    primaryCta={{ href: '/quote?type=Wedding', label: 'Start a wedding quote' }}
    secondaryCta={{ href: '/portfolio', label: 'See wedding work' }}
    image={products[0]?.image.src ?? entry.data.heroImage}
    imageAlt={products[0]?.image.alt ?? entry.data.heroAlt}
    imageHref="https://shop.balloonia.events/collections/weddings"
    imageOverlay="Click to order online"
    variant="page"
  />

  <section class="icp-body section">
    <div class="container container-narrow prose">
      <Content />
    </div>
  </section>

  {portfolio.length > 0 && (
    <section class="icp-portfolio section">
      <div class="container">
        <p class="eyebrow">Recent weddings</p>
        <h2>Wedding work</h2>
        <ul class="portfolio-grid-icp">
          {portfolio.map((item) => (
            <li>
              <img src={item.data.image} alt={item.data.alt} loading="lazy" />
            </li>
          ))}
        </ul>
        <a class="section-link" href="/portfolio">See full portfolio →</a>
      </div>
    </section>
  )}

  {products.length > 0 && (
    <section class="icp-products section">
      <div class="container">
        <header class="section-head">
          <p class="eyebrow">Shop the catalog</p>
          <h2>Wedding balloon products</h2>
          <p class="lede">Browse the catalog tagged for weddings. Every product is also available custom-built to your colors and venue.</p>
        </header>
        <ProductGrid products={products} columns={3} />
        <p class="section-link-wrap">
          <a class="section-link" href="https://shop.balloonia.events/collections/weddings">View all wedding products →</a>
        </p>
      </div>
    </section>
  )}

  <section class="icp-cta section">
    <div class="container container-narrow text-center">
      <p class="eyebrow">Get started</p>
      <h2>Tell us about your wedding.</h2>
      <p class="lede">A few minutes now saves a back-and-forth later. Brenda quotes within 24 hours.</p>
      <div class="icp-cta-buttons">
        <CTAButton href="/quote" variant="primary" size="lg">Start your quote</CTAButton>
        <CTAButton href="/portfolio" variant="secondary" size="lg">See wedding work</CTAButton>
      </div>
    </div>
  </section>

  {weddingReviews.length > 0 && (
    <ReviewsSlider reviews={weddingReviews} heading="What past wedding clients have said." />
  )}

  <FAQAccordion heading="Wedding FAQs" faqs={faqs} />
</BaseLayout>

<style>
  .prose h2 {
    margin-top: var(--space-7);
  }
  .prose ul {
    color: var(--color-ink-soft);
  }
  .portfolio-grid-icp {
    list-style: none;
    margin: var(--space-5) 0 var(--space-5);
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
  }
  .portfolio-grid-icp li {
    margin: 0;
  }
  .portfolio-grid-icp img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: var(--radius-md);
    background: var(--color-paper-edge);
  }
  .section-link {
    color: var(--color-accent-deep);
    font-size: var(--font-size-sm);
    font-weight: 500;
    text-decoration: underline;
    text-underline-offset: 4px;
  }
  .section-head {
    margin-bottom: var(--space-6);
  }
  .icp-cta {
    background: var(--color-paper-soft);
  }
  .text-center { text-align: center; }
  .text-center p { margin-left: auto; margin-right: auto; }
  .icp-cta-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    justify-content: center;
    margin-top: var(--space-6);
  }
  @media (min-width: 640px) {
    .portfolio-grid-icp {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (min-width: 960px) {
    .portfolio-grid-icp {
      grid-template-columns: repeat(6, 1fr);
    }
  }
</style>
